{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "bogon": {
      "type": "boolean"
    },
    "city": {
      "type": ["string", "null"]
    },
    "countryCode": {
      "type": "string",
      "minLength": 2,
      "maxLength": 2
    },
    "countryName": {
      "type": "string"
    },
    "ip": {
      "type": "string",
      "pattern": "^(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$"
    },
    "loc": {
      "type": ["string", "null"],
      "pattern": "^(-?\\d{1,3}\\.\\d+),\\s*(-?\\d{1,3}\\.\\d+)$"
    },
    "region": {
      "type": ["string", "null"]
    }
  },
  "required": ["bogon", "countryCode", "countryName", "ip"]
}
