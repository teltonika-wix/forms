{
  "name": "wix-form",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build && vp run build:custom-elements",
    "build:custom-elements": "vp build --config vite.custom-elements.config.ts",
    "build:worker": "vp build && vp run build:custom-elements",
    "deploy:worker": "vp run build:worker && wrangler deploy --config wrangler.toml --env-file .env && vp run purge:worker-cache",
    "dev:worker": "vp run build:worker && wrangler dev --config wrangler.toml --env-file .env",
    "preview": "vp preview",
    "preview:custom-elements": "vp dev --open /custom-elements-preview.html?mockForms=1",
    "test": "vp test",
    "test:run": "vp test --run",
    "test:watch": "vp test --watch",
    "prepare": "vp config",
    "arch:check": "node scripts/check-architecture.mjs",
    "arch:baseline": "node scripts/check-architecture.mjs --update-baseline",
    "purge:worker-cache": "node scripts/purge-cloudflare-cache.mjs"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@heroicons/vue": "^2.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.10",
    "@vueuse/core": "^14.3.0",
    "jsdom": "^29.1.1",
    "sass-embedded": "^1.99.0",
    "tailwind-variants": "^3.2.2",
    "typescript": "~6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.20",
    "wrangler": "latest"
  },
  "packageManager": "pnpm@10.33.3",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
